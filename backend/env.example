# Database
DATABASE_URL=sqlite+aiosqlite:///./data/study.db

# Auth (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
SECRET_KEY=replace_with_random_secret_at_least_32_chars
# Optional. Defaults to SECRET_KEY if empty. Keep stable or saved AI keys cannot be decrypted.
AI_KEY_ENCRYPTION_SECRET=

# AI Provider Configuration
# 选择默认的 AI 提供商: openai, claude, gemini, qwen
DEFAULT_AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-opus-20240229

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Qwen
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-turbo

# Server
HOST=0.0.0.0
PORT=8000
# Use DEBUG=True only for local development. Production startup rejects weak SECRET_KEY values.
DEBUG=False
ENVIRONMENT=development

# CORS: set this to your exact frontend origin(s) in production; do not use '*'.
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Upload limits
MATERIAL_UPLOAD_MAX_MB=200
MAX_REQUEST_BODY_MB=20

# Production protection
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=10
