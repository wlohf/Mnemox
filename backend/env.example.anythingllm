# =================================
# StudyAssistant + AnythingLLM 配置
# =================================
# 复制此文件为 .env 并填入实际值

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/study.db

# ============ AI 提供商配置 ============
DEFAULT_AI_PROVIDER=openai

# OpenAI (用于 AnythingLLM 的 LLM 功能)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude (可选)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-5-20251101
CLAUDE_BASE_URL=https://wzw.pp.ua

# Gemini (可选)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# ============ AnythingLLM RAG 系统配置 ============
# 是否启用 AnythingLLM 集成
ANYTHINGLLM_ENABLED=true

# AnythingLLM 服务器地址（默认 3001 端口）
ANYTHINGLLM_BASE_URL=http://localhost:3001

# API 密钥（如果 AnythingLLM 启用了身份验证）
# 在 AnythingLLM 的设置中可以生成 API Key
ANYTHINGLLM_API_KEY=

# 默认工作空间名称（上传的资料会自动添加到这个工作空间）
ANYTHINGLLM_WORKSPACE=study-materials

# ============ 服务器配置 ============
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS 允许的源（前端地址）
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# ============ 说明 ============
# 1. 必须先启动 AnythingLLM 的 server 和 collector 服务
# 2. 运行 python test_integration.py 测试连接
# 3. 如果不使用 AnythingLLM，将 ANYTHINGLLM_ENABLED 设为 false
# 4. 可以使用本地 LLM (如 Ollama) 替代 OpenAI，在 AnythingLLM Web 界面配置
