{
  "version": 1,
  "description": "Deterministic goal-driven Agent Memory eval cases. These cases avoid real LLM calls by default and exercise service contracts through seeded SQLite state.",
  "defaults": {
    "today": "2026-06-23",
    "now": "2026-06-23T09:00:00"
  },
  "cases": [
