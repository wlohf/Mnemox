      "category": "goal_creation",
      "evaluator": "write_draft",
      "message": "新建目标：两周提升英语听力，任务：每天精听20分钟",
      "expected": {"intent": "create_goal_tasks", "goal_title": "两周提升英语听力", "task_titles_include": ["每天精听20分钟"], "requires_confirmation": true}
    },
    {
      "id": "goal-create-math-sprint",
      "category": "goal_creation",
      "evaluator": "write_draft",
      "message": "创建目标：十天掌握线性代数行列式，任务：每天刷10道题，总结错题",
      "expected": {"intent": "create_goal_tasks", "goal_title": "十天掌握线性代数行列式", "task_titles_include": ["每天刷10道题", "总结错题"], "requires_confirmation": true}
    },
